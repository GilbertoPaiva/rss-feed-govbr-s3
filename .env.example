# Credenciais da AWS (opcional se usar S3_ENDPOINT público)
AWS_ACCESS_KEY_ID=sua_access_key_aqui
AWS_SECRET_ACCESS_KEY=sua_secret_key_aqui
AWS_REGION=us-east-1
AWS_S3_BUCKET=nome-do-seu-bucket

# Endpoint S3 público (use isso em vez das credenciais AWS para acesso público)
# S3_ENDPOINT=https://nome-do-seu-bucket.s3.amazonaws.com

# Configuração do servidor
PORT=3000

# URLs das fontes RSS
RSS_URL_GOVBR=https://www.gov.br/rss
RSS_URL_G1=https://g1.globo.com/rss/g1/